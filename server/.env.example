

# ============================================
# Panchavati Hotel Server - Environment Variables
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=panchavati_hotel

# JWT
JWT_SECRET=abcdefg123456
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880


